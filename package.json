{
  "name": "clarifi-desktop",
  "version": "0.1.0",
  "description": "Clarifi — AI meeting co-pilot desktop overlay",
  "author": {
    "name": "Tayo",
    "email": "tayowilliams23@gmail.com"
  },
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "electron:dev": "cross-env NODE_ENV=development vite",
    "electron:onboarding": "cross-env NODE_ENV=development FORCE_ONBOARDING=1 vite",
    "electron:dev-shell": "cross-env NODE_ENV=development CLARIFI_DEV_SHELL=1 vite",
    "build": "tsc --noEmit && vite build",
    "build:icons": "bash scripts/build-icons.sh",
    "build:helper:mac": "bash swift/compile.sh && bash scripts/build-native.sh",
    "build:native": "bash scripts/build-native.sh",
    "prebuild:mac": "npm run build:helper:mac",
    "prebuild:win": "node -e \"console.log('Skipping macOS-only helpers on Windows')\"",
    "build:mac": "tsc --noEmit && vite build && electron-builder --mac",
    "build:mac:release": "bash scripts/build-mac-release.sh",
    "build:win": "tsc --noEmit && vite build && electron-builder --win",
    "preview": "vite preview"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "electron-updater": "^6.3.9",
    "form-data": "^4.0.5",
    "keytar": "^7.9.0",
    "node-fetch": "^2.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
