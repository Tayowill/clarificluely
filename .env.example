# Clarifi cloud API (recommended — users pay via your backend, not BYOK)
CLARIFI_API_URL=http://localhost:3000
# Connect: sign in on web → Open Clarifi Desktop → clarifi:// auth deep link

# Legacy BYOK fallback (only used when CLARIFI_API_URL + token are not set)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Packaged app: ~/Library/Application Support/Clarifi/.env with CLARIFI_API_URL + token

# Signed Mac DMG (Gatekeeper): copy .env.signing.example → .env.signing.local, then:
#   ./scripts/setup-mac-signing.sh

# Auto-update GitHub repo (set when publishing releases)
GH_UPDATE_OWNER=your-github-org
GH_UPDATE_REPO=clarifi-desktop
