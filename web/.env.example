# Waitlist auth (Supabase) — required for homepage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk — optional while waitlist is live; still used by /desktop/* and /dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe webhook is handled by Supabase Edge Function (not Next.js):
# https://<project-ref>.supabase.co/functions/v1/stripe-webhook
# Edge function secrets (Supabase dashboard — names cannot start with SUPABASE_):
#   STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET, STRIPE_PRICE_PRO, STRIPE_PRICE_PRO_PLUS, SERVICE_ROLE_KEY
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_PLUS=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_PRO=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_PRO_PLUS=

# Server-side LLM keys (never exposed to desktop clients)
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# Pepper for hashing desktop device secrets (server-only)
DEVICE_AUTH_PEPPER=

# Clerk user IDs that bypass rate limits and get Pro+ (comma-separated)
CREATOR_CLERK_USER_IDS=

NEXT_PUBLIC_CLARIFI_MAC_DOWNLOAD_URL=
NEXT_PUBLIC_APP_URL=https://www.clarifiapp.com

# Legacy alias — use NEXT_PUBLIC_SUPABASE_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
